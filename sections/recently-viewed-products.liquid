{% liquid
  assign current_id = ''
  if request.page_type == 'product'
    assign current_id = product.id | json
  endif
%}

<div
  class="section section--{{ section.settings.section_width }} spacing-style color-{{ section.settings.color_scheme }} recently-viewed-section"
  style="{% render 'spacing-style', settings: section.settings %}"
  data-testid="recently-viewed-products"
>
  <recently-viewed-products
    class="recently-viewed"
    data-current-product-id="{{ current_id | strip }}"
    data-max-items="{{ section.settings.max_products }}"
    data-currency="{{ shop.currency }}"
    hidden
  >
    <div class="recently-viewed__header">
      <h3 class="recently-viewed__heading">{{ section.settings.heading | default: 'Recently Viewed' }}</h3>
    </div>
    <ul class="recently-viewed__grid" data-recently-viewed-list></ul>
  </recently-viewed-products>
</div>

<script type="module">
  import { RecentlyViewed } from {{ 'recently-viewed-products.js' | asset_url | json }};

  class RecentlyViewedProducts extends HTMLElement {
    async connectedCallback() {
      const max = parseInt(this.dataset.maxItems || '4', 10);
      const currentId = this.dataset.currentProductId;
      const entries = RecentlyViewed.getProducts()
        .filter((p) => String(p.id) !== String(currentId))
        .slice(0, max);

      if (!entries.length) return;

      const list = this.querySelector('[data-recently-viewed-list]');
      if (!list) return;

      const results = await Promise.all(entries.map((p) => this.#fetchProduct(p.handle)));
      const cards = results.filter(Boolean).map((p) => this.#renderCard(p));
      if (!cards.length) return;

      list.innerHTML = cards.join('');
      this.hidden = false;
    }

    async #fetchProduct(handle) {
      if (!handle) return null;
      try {
        const res = await fetch(`/products/${encodeURIComponent(handle)}.js`, {
          headers: { Accept: 'application/json' },
        });
        if (!res.ok) return null;
        return await res.json();
      } catch (_) {
        return null;
      }
    }

    #formatPrice(cents) {
      if (cents == null) return '';
      const amount = (cents / 100).toFixed(0);
      // Match Shopify default Rp formatting (no decimals, comma thousands).
      const withSeparators = amount.replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      return `Rp ${withSeparators}`;
    }

    #renderCard(p) {
      const url = p.url || `/products/${p.handle}`;
      const title = p.title || '';
      const price = this.#formatPrice(p.price);
      const img = p.featured_image
        ? p.featured_image.replace(/(\.(jpe?g|png|webp|avif|gif))/i, '_500x$1')
        : '';
      const imgTag = img
        ? `<img src="${img}" alt="${this.#escape(title)}" loading="lazy" width="400" height="500">`
        : '';
      return `
        <li class="recently-viewed__item">
          <a class="recently-viewed__link" href="${url}">
            <div class="recently-viewed__media">${imgTag}</div>
            <div class="recently-viewed__meta">
              <span class="recently-viewed__title">${this.#escape(title)}</span>
              <span class="recently-viewed__price">${price}</span>
            </div>
          </a>
        </li>
      `;
    }

    #escape(str) {
      return String(str).replace(/[&<>"']/g, (ch) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      }[ch]));
    }
  }

  if (!customElements.get('recently-viewed-products')) {
    customElements.define('recently-viewed-products', RecentlyViewedProducts);
  }
</script>

{% stylesheet %}
  .recently-viewed[hidden] { display: none; }

  .recently-viewed__header {
    text-align: center;
    margin-block-end: 24px;
  }

  .recently-viewed__heading {
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-size: clamp(18px, 2vw, 22px);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-foreground, #454545);
    margin: 0;
  }

  .recently-viewed__grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }

  @media screen and (min-width: 750px) {
    .recently-viewed__grid { grid-template-columns: repeat(4, 1fr); }
  }

  .recently-viewed__link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .recently-viewed__media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--color-background, #fff);
  }

  .recently-viewed__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .recently-viewed__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding-block-start: 8px;
  }

  .recently-viewed__title {
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-size: 14px;
    text-transform: uppercase;
    color: var(--color-foreground, #454545);
  }

  .recently-viewed__price {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 14px;
    color: var(--color-foreground, #454545);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Recently viewed",
  "tag": "section",
  "class": "recently-viewed-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently Viewed"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Section width",
      "options": [
        { "value": "page-width", "label": "Page" },
        { "value": "full-width", "label": "Full" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Recently viewed"
    }
  ]
}
{% endschema %}
