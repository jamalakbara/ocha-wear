{%- liquid
  assign slide_count = section.blocks.size
  assign autoplay = section.settings.autoplay
  assign autoplay_speed = section.settings.autoplay_speed | times: 1000
  assign show_dots = section.settings.show_dots
  assign desktop_height = section.settings.desktop_height | default: 'full'
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{%- render 'duma-section-spacing', section: section -%}

<section
  class="duma-hero duma-hero--{{ desktop_height }} section section--full-width disable-section-top-offset color-{{ section.settings.color_scheme }}"
  id="DumaHero-{{ section.id }}"
  data-duma-hero
  {% if autoplay and slide_count > 1 %}data-autoplay="{{ autoplay_speed }}"{% endif %}
  style="--duma-hero-min-height: {{ section.settings.min_height }}px;"
>
  <div class="duma-hero__slides" data-duma-hero-slides>
    {%- for block in section.blocks -%}
      {%- assign slide_url = block.settings.link -%}
      {%- capture slide_body -%}
        {%- render 'duma-hero-slide-media', block: block -%}
        <span class="duma-hero__scrim" aria-hidden="true"></span>
        {%- if block.settings.wordmark != blank -%}
          <span class="duma-hero__wordmark-wrap">
            <span class="duma-hero__wordmark">{{ block.settings.wordmark }}</span>
            {%- if block.settings.subline != blank -%}
              <span class="duma-hero__subline">{{ block.settings.subline }}</span>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <span class="duma-hero__cta">{{ block.settings.cta_label }}</span>
            {%- endif -%}
          </span>
        {%- endif -%}
      {%- endcapture -%}

      {%- if slide_url != blank -%}
        <a
          class="duma-hero__slide{% if forloop.first %} is-active{% endif %}"
          href="{{ slide_url }}"
          data-duma-hero-slide
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >{{ slide_body }}</a>
      {%- else -%}
        <div
          class="duma-hero__slide{% if forloop.first %} is-active{% endif %}"
          data-duma-hero-slide
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >{{ slide_body }}</div>
      {%- endif -%}
    {%- else -%}
      <div class="duma-hero__slide is-active" data-duma-hero-slide data-index="0">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'duma-hero__media duma-hero__media-only' }}
        <span class="duma-hero__wordmark-wrap">
          <span class="duma-hero__wordmark">ocha wear</span>
        </span>
      </div>
    {%- endfor -%}
  </div>

  {%- if show_dots and slide_count > 1 -%}
    <div class="duma-hero__dots" data-duma-hero-dots>
      {%- for block in section.blocks -%}
        <button
          type="button"
          class="duma-hero__dot{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="Go to slide {{ forloop.index }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .duma-hero {
    position: relative;
    width: 100%;
    height: 100svh;
    min-height: var(--duma-hero-min-height, 660px);
    margin: 0;
    padding: 0;
    overflow: hidden;
    background: #ece9e0;
  }

  /* Presets ignore the min-height floor — it only guards full-screen mode */
  .duma-hero--small { height: 50svh; min-height: 0; }
  .duma-hero--medium { height: 70svh; min-height: 0; }
  .duma-hero--large { height: 85svh; min-height: 0; }

  .duma-hero__slides {
    position: absolute;
    inset: 0;
  }

  .duma-hero__slide {
    position: absolute;
    inset: 0;
    display: block;
    color: #fff;
    text-decoration: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 1.2s ease, visibility 1.2s ease;
    will-change: opacity;
  }

  .duma-hero__slide.is-active {
    opacity: 1;
    visibility: visible;
  }

  .duma-hero__media,
  .duma-hero__media-mobile,
  .duma-hero__media-desktop,
  .duma-hero__media-only {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .duma-hero__media-mobile { display: block; }
  .duma-hero__media-desktop { display: none; }

  @media screen and (min-width: 750px) {
    .duma-hero__media-mobile { display: none; }
    .duma-hero__media-desktop { display: block; }
  }

  .duma-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0) 32%, rgba(0, 0, 0, 0) 70%, rgba(0, 0, 0, 0.16) 100%);
    z-index: 1;
  }

  .duma-hero__wordmark-wrap {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.15rem;
    text-align: center;
    padding: 0 1.5rem;
    z-index: 2;
  }

  .duma-hero__wordmark {
    color: #fff;
    font-family: var(--font-duma-display, var(--font-heading--family));
    font-weight: 500;
    font-style: normal;
    font-size: clamp(4.5rem, 12vw, 11.5rem);
    line-height: 1;
    letter-spacing: 0.01em;
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.18);
  }

  .duma-hero__subline {
    color: #fff;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: clamp(0.8125rem, 1vw, 0.9375rem);
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .duma-hero__cta {
    margin-top: 0.35rem;
    color: #fff;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding-bottom: 5px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.85);
    transition: border-color 0.3s ease;
  }

  .duma-hero__slide:hover .duma-hero__cta {
    border-color: #fff;
  }

  .duma-hero__dots {
    position: absolute;
    left: 50%;
    bottom: 30px;
    transform: translateX(-50%);
    display: flex;
    gap: 11px;
    z-index: 4;
  }

  .duma-hero__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.45);
    cursor: pointer;
    transition: background 0.3s ease, transform 0.3s ease;
  }

  .duma-hero__dot.is-active {
    background: #fff;
    transform: scale(1.25);
  }

  @media screen and (max-width: 680px) {
    .duma-hero__wordmark { font-size: clamp(3.5rem, 16vw, 4rem); }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('DumaHero-{{ section.id }}');
    if (!root) return;

    var slides = Array.prototype.slice.call(root.querySelectorAll('[data-duma-hero-slide]'));
    var dots = Array.prototype.slice.call(root.querySelectorAll('.duma-hero__dot'));
    if (slides.length < 2) return;

    var current = 0;
    var delay = parseInt(root.getAttribute('data-autoplay'), 10) || 0;
    var timer = null;

    function go(n) {
      current = (n + slides.length) % slides.length;
      slides.forEach(function (s, i) { s.classList.toggle('is-active', i === current); });
      dots.forEach(function (d, i) { d.classList.toggle('is-active', i === current); });
    }

    function start() {
      if (!delay) return;
      stop();
      timer = setInterval(function () { go(current + 1); }, delay);
    }
    function stop() { if (timer) { clearInterval(timer); timer = null; } }

    dots.forEach(function (d) {
      d.addEventListener('click', function (e) {
        e.preventDefault();
        go(parseInt(d.getAttribute('data-index'), 10));
        start();
      });
    });

    root.addEventListener('mouseenter', stop);
    root.addEventListener('mouseleave', start);
    start();
  })();
</script>

{% schema %}
{
  "name": "DUMA Hero",
  "class": "container-background-image",
  "tag": "section",
  "blocks": [
    {
      "type": "duma-hero-slide",
      "name": "Hero slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image",
          "info": "Recommended: 2880 × 1620px (landscape). Safe for full-screen height."
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image (1:1)",
          "info": "Recommended: 1200 × 1200px (square). Falls back to the desktop image if empty."
        },
        {
          "type": "text",
          "id": "wordmark",
          "label": "Wordmark",
          "info": "Display serif text centered over the image (e.g. campaign name)."
        },
        {
          "type": "text",
          "id": "subline",
          "label": "Subline",
          "info": "Small caps line under the wordmark."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "SHOP NOW"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "desktop_height",
      "label": "Height",
      "options": [
        { "value": "small", "label": "Small (50% screen)" },
        { "value": "medium", "label": "Medium (70% screen)" },
        { "value": "large", "label": "Large (85% screen)" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "info": "Full-screen hero never shrinks below this.",
      "min": 320,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 660,
      "visible_if": "{{ section.settings.desktop_height == 'full' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-6"
    },
    {
      "type": "header",
      "content": "Slideshow"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate slides",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Rotate every",
      "min": 2,
      "max": 12,
      "step": 0.5,
      "unit": "s",
      "default": 6,
      "visible_if": "{{ section.settings.autoplay }}"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show pagination dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "checkbox",
      "id": "custom_spacing",
      "label": "Override theme section gap",
      "info": "Default gap comes from Theme settings > DUMA Layout.",
      "default": false
    },
    {
      "type": "range",
      "id": "space_above",
      "label": "Space above",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    },
    {
      "type": "range",
      "id": "space_below",
      "label": "Space below",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    }
  ],
  "presets": [
    {
      "name": "DUMA Hero",
      "category": "t:categories.banners",
      "settings": {},
      "blocks": {
        "slide_1": {
          "type": "duma-hero-slide",
          "settings": {
            "wordmark": "ocha wear",
            "subline": "OUT NOW"
          }
        }
      },
      "block_order": ["slide_1"]
    }
  ]
}
{% endschema %}
