{%- liquid
  assign collection = section.settings.collection
  assign max_items = section.settings.max_products
  assign heading = section.settings.heading
  assign foot_label = section.settings.foot_label
  assign foot_link = section.settings.foot_link
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>

<section
  class="duma-picks section section--full-width color-{{ section.settings.color_scheme }}"
  id="DumaPicks-{{ section.id }}"
  data-section-id="{{ section.id }}"
>
  {%- if heading != blank -%}
    <h2 class="duma-picks__heading">{{ heading }}</h2>
  {%- endif -%}

  <div class="duma-picks__wrap">
    <button type="button" class="duma-picks__arrow duma-picks__arrow--prev is-hidden" data-duma-prev aria-label="Previous">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7"/></svg>
    </button>
    <button type="button" class="duma-picks__arrow duma-picks__arrow--next" data-duma-next aria-label="Next">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7"/></svg>
    </button>

    <div class="duma-picks__track" data-duma-track>
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products limit: max_items -%}
          {%- liquid
            assign variant = product.selected_or_first_available_variant
            assign on_sale = false
            if product.compare_at_price_max > product.price
              assign on_sale = true
            endif
            assign primary = product.featured_media
            assign alt_media = product.media[1]
            assign pick_form_id = 'DumaPickForm-' | append: section.id | append: '-' | append: product.id
          -%}
          <div class="duma-pick">
            <a class="duma-pick__imgwrap" href="{{ product.url }}" data-duma-card-link>
              {%- unless product.available -%}
                <span class="duma-pick__badge duma-pick__badge--sold">Sold out</span>
              {%- elsif on_sale -%}
                <span class="duma-pick__badge">On sale</span>
              {%- elsif product.tags contains 'new' -%}
                <span class="duma-pick__badge">New</span>
              {%- endunless -%}

              {%- if primary != blank -%}
                <img
                  class="duma-pick__photo duma-pick__photo--primary"
                  src="{{ primary | image_url: width: 800 }}"
                  srcset="{{ primary | image_url: width: 400 }} 400w, {{ primary | image_url: width: 800 }} 800w"
                  sizes="(min-width: 750px) 24vw, 60vw"
                  alt="{{ primary.alt | escape | default: product.title }}"
                  loading="lazy"
                  width="{{ primary.preview_image.width }}"
                  height="{{ primary.preview_image.height }}"
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'duma-pick__photo duma-pick__photo--primary' }}
              {%- endif -%}

              {%- if alt_media != blank -%}
                <img
                  class="duma-pick__photo duma-pick__photo--alt"
                  src="{{ alt_media | image_url: width: 800 }}"
                  srcset="{{ alt_media | image_url: width: 400 }} 400w, {{ alt_media | image_url: width: 800 }} 800w"
                  sizes="(min-width: 750px) 24vw, 60vw"
                  alt=""
                  loading="lazy"
                  width="{{ alt_media.preview_image.width }}"
                  height="{{ alt_media.preview_image.height }}"
                >
              {%- endif -%}
            </a>

            <div class="duma-pick__info">
              <a class="duma-pick__name" href="{{ product.url }}" data-duma-card-link>{{ product.title }}</a>
              <div class="duma-pick__price">
                {%- if on_sale -%}
                  <span class="duma-pick__was">{{ product.compare_at_price_max | money }}</span>
                  <span class="duma-pick__now">{{ product.price | money }}</span>
                {%- else -%}
                  <span>{{ product.price | money }}</span>
                {%- endif -%}
              </div>

              {%- if product.available -%}
                <product-form-component
                  class="duma-pick__form"
                  data-section-id="{{ section.id }}"
                  data-product-id="{{ product.id }}"
                  data-product-url="{{ product.url }}"
                  on:submit="/handleSubmit"
                >
                  {%- form 'product', product, id: pick_form_id, data-type: 'add-to-cart-form' -%}
                    <input type="hidden" name="id" ref="variantId" value="{{ variant.id }}">
                    <button type="submit" name="add" class="duma-pick__add">Add to Bag</button>
                  {%- endform -%}
                </product-form-component>
              {%- else -%}
                <button type="button" class="duma-pick__add" disabled>Notify Me</button>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}
          <div class="duma-pick">
            <div class="duma-pick__imgwrap">
              {{ 'product-1' | placeholder_svg_tag: 'duma-pick__photo duma-pick__photo--primary' }}
            </div>
            <div class="duma-pick__info">
              <span class="duma-pick__name">Product title</span>
              <div class="duma-pick__price"><span>$0</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  {%- if foot_label != blank -%}
    <div class="duma-picks__foot">
      <a href="{{ foot_link | default: collection.url }}">
        {{ foot_label }}<span class="duma-picks__foot-arrow">&rarr;</span>
      </a>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .duma-picks {
    width: 100%;
    margin: 0;
    padding: 66px 0 30px;
  }

  .duma-picks__heading {
    margin: 0 0 42px;
    text-align: center;
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-weight: 500;
    font-size: 1.625rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--color-foreground, #666);
  }

  .duma-picks__wrap {
    position: relative;
  }

  .duma-picks__track {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0 8px;
    scrollbar-width: none;
    cursor: grab;
  }

  .duma-picks__track::-webkit-scrollbar { display: none; }

  .duma-picks__track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  .duma-pick {
    flex: 0 0 clamp(280px, 24vw, 360px);
    position: relative;
  }

  .duma-pick__imgwrap {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #f3f1ec;
  }

  .duma-pick__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.45s ease;
  }

  .duma-pick__photo--alt { opacity: 0; }
  .duma-pick:hover .duma-pick__photo--primary { opacity: 0; }
  .duma-pick:hover .duma-pick__photo--alt { opacity: 1; }

  .duma-pick__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 3;
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-foreground, #454545);
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    padding: 5px 11px;
  }

  .duma-pick__badge--sold {
    background: rgba(54, 54, 54, 0.82);
    color: #fff;
  }

  .duma-pick__info {
    text-align: center;
    padding: 18px 8px 6px;
  }

  .duma-pick__name {
    display: block;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.9375rem;
    color: var(--color-foreground, #454545);
    margin-bottom: 7px;
    text-decoration: none;
  }

  .duma-pick__price {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.875rem;
    color: #666;
    display: inline-flex;
    gap: 9px;
    align-items: baseline;
    justify-content: center;
  }

  .duma-pick__was {
    text-decoration: line-through;
    color: #b3b3b3;
    font-size: 0.8125rem;
  }

  .duma-pick__now { color: #c8232c; }

  .duma-pick__form { display: block; }

  .duma-pick__add {
    margin-top: 13px;
    display: inline-block;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-foreground, #454545);
    background: none;
    border: none;
    border-bottom: 1px solid currentColor;
    padding: 0 0 3px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .duma-pick:hover .duma-pick__add {
    opacity: 1;
    transform: translateY(0);
  }

  .duma-pick__add[disabled] {
    color: #b3b3b3;
    border-color: #d8d8d8;
    cursor: default;
  }

  .duma-picks__arrow {
    position: absolute;
    top: 38%;
    z-index: 5;
    width: 54px;
    height: 54px;
    border: none;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .duma-picks__arrow:hover { transform: scale(1.08); }
  .duma-picks__arrow svg { width: 20px; height: 20px; stroke: var(--color-foreground, #454545); fill: none; stroke-width: 1.5; }
  .duma-picks__arrow--prev { left: 18px; }
  .duma-picks__arrow--next { right: 18px; }

  .duma-picks__arrow.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .duma-picks__foot {
    text-align: center;
    padding: 46px 0 8px;
  }

  .duma-picks__foot a {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.8125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-foreground, #454545);
    display: inline-flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    white-space: nowrap;
  }

  .duma-picks__foot-arrow { transition: transform 0.3s ease; }
  .duma-picks__foot a:hover .duma-picks__foot-arrow { transform: translateX(6px); }

  @media screen and (max-width: 749px) {
    .duma-picks__arrow { display: none; }
    .duma-pick { flex-basis: 60vw; }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('DumaPicks-{{ section.id }}');
    if (!root) return;

    var track = root.querySelector('[data-duma-track]');
    var prev = root.querySelector('[data-duma-prev]');
    var next = root.querySelector('[data-duma-next]');
    if (!track) return;

    function step() {
      var card = track.querySelector('.duma-pick');
      return card ? card.offsetWidth + 8 : 320;
    }

    if (next) next.addEventListener('click', function () { track.scrollBy({ left: step() * 2, behavior: 'smooth' }); });
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step() * 2, behavior: 'smooth' }); });

    function updateArrows() {
      if (prev) prev.classList.toggle('is-hidden', track.scrollLeft < 8);
      if (next) next.classList.toggle('is-hidden', track.scrollLeft > track.scrollWidth - track.clientWidth - 8);
    }
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);
    updateArrows();

    // drag to scroll
    var down = false, startX = 0, startScroll = 0, moved = 0;
    track.addEventListener('mousedown', function (e) {
      down = true; moved = 0; startX = e.pageX; startScroll = track.scrollLeft;
      track.classList.add('is-dragging');
    });
    window.addEventListener('mouseup', function () { down = false; track.classList.remove('is-dragging'); });
    window.addEventListener('mousemove', function (e) {
      if (!down) return;
      var dx = e.pageX - startX;
      moved += Math.abs(dx);
      track.scrollLeft = startScroll - dx;
    });
    track.querySelectorAll('[data-duma-card-link]').forEach(function (link) {
      link.addEventListener('click', function (e) { if (moved > 6) e.preventDefault(); });
    });
  })();
</script>

{% schema %}
{
  "name": "DUMA Our Picks",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Picks"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "text",
      "id": "foot_label",
      "label": "Footer link label",
      "default": "View All Products →"
    },
    {
      "type": "url",
      "id": "foot_link",
      "label": "Footer link URL",
      "info": "Defaults to the selected collection."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "DUMA Our Picks",
      "category": "t:categories.product",
      "settings": {
        "heading": "Our Picks",
        "max_products": 12
      }
    }
  ]
}
{% endschema %}
