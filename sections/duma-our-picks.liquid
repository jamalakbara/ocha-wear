{%- liquid
  assign collection = section.settings.collection
  assign max_items = section.settings.max_products
  assign heading = section.settings.heading
  assign foot_label = section.settings.foot_label
  assign foot_link = section.settings.foot_link
  assign source = section.settings.source | default: 'collection'

  # Resolve the product list.
  # "related" uses Shopify product recommendations, "recently_viewed" uses the
  # visitor's localStorage history resolved through the search endpoint.
  # Both render empty on first paint and hydrate client-side via a fetch that
  # re-renders this section with the relevant object populated.
  assign pick_products = blank
  assign awaiting_hydration = false
  if source == 'related' and product != blank
    if recommendations.performed
      if recommendations.products_count > 0
        assign pick_products = recommendations.products
      else
        assign pick_products = collection.products
      endif
    else
      assign awaiting_hydration = true
    endif
  elsif source == 'recently_viewed'
    if search.performed
      assign pick_products = search.results | where: 'object_type', 'product'
    else
      assign awaiting_hydration = true
    endif
  else
    assign pick_products = collection.products
  endif
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{%- render 'duma-section-spacing', section: section -%}

<section
  class="duma-picks section section--full-width color-{{ section.settings.color_scheme }}"
  id="DumaPicks-{{ section.id }}"
  data-section-id="{{ section.id }}"
  {% if awaiting_hydration %}
    hidden
  {% endif %}
  {% if awaiting_hydration and source == 'related' %}
    data-recommendations-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ max_items }}&intent=related"
  {% endif %}
  {% if awaiting_hydration and source == 'recently_viewed' %}
    data-recently-viewed-url="{{ routes.search_url }}"
    data-max-items="{{ max_items }}"
    {% if product != blank %}data-current-product-id="{{ product.id }}"{% endif %}
  {% endif %}
>
  {%- if heading != blank -%}
    <h2 class="duma-picks__heading">{{ heading }}</h2>
  {%- endif -%}

  <div class="duma-picks__wrap">
    <button type="button" class="duma-picks__arrow duma-picks__arrow--prev is-hidden" data-duma-prev aria-label="Previous">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m15 5-7 7 7 7"/></svg>
    </button>
    <button type="button" class="duma-picks__arrow duma-picks__arrow--next" data-duma-next aria-label="Next">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m9 5 7 7-7 7"/></svg>
    </button>

    <div class="duma-picks__track" data-duma-track>
      {%- if pick_products != blank and pick_products.size > 0 -%}
        {%- for pick_product in pick_products limit: max_items -%}
          {% render 'duma-pick-card', card_product: pick_product, section_id: section.id %}
        {%- endfor -%}
      {%- elsif awaiting_hydration == false -%}
        {%- for i in (1..6) -%}
          <div class="duma-pick">
            <div class="duma-pick__imgwrap">
              {{ 'product-1' | placeholder_svg_tag: 'duma-pick__photo duma-pick__photo--primary' }}
            </div>
            <div class="duma-pick__info">
              <span class="duma-pick__name">Product title</span>
              <div class="duma-pick__price"><span>$0</span></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>

  {%- if foot_label != blank -%}
    <div class="duma-picks__foot">
      <a href="{{ foot_link | default: collection.url }}">
        {{ foot_label }}<span class="duma-picks__foot-arrow">&rarr;</span>
      </a>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .duma-picks {
    width: 100%;
    margin: 0;
    padding: 66px 0 30px;
  }

  /* base.css `.section { display: grid }` would beat the UA [hidden] rule */
  .duma-picks[hidden] {
    display: none !important;
  }

  .duma-picks__heading {
    margin: 0 0 42px;
    text-align: center;
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-style: italic;
    font-weight: 600;
    font-size: 1.875rem;
    letter-spacing: -0.02em;
    text-transform: none;
    color: var(--color-foreground, #2b2b2b);
  }

  .duma-picks__wrap {
    position: relative;
  }

  .duma-picks__track {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 0 8px;
    scrollbar-width: none;
    cursor: grab;
  }

  .duma-picks__track::-webkit-scrollbar { display: none; }

  .duma-picks__track.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
  }

  /* All products fit in the viewport — no carousel needed */
  .duma-picks--static .duma-picks__track {
    justify-content: center;
    cursor: default;
  }

  .duma-picks--static .duma-picks__arrow {
    display: none;
  }

  .duma-pick {
    flex: 0 0 clamp(280px, 24vw, 360px);
    position: relative;
  }

  .duma-pick__imgwrap {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: #eef0e6;
  }

  .duma-pick__photo {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.45s ease;
  }

  .duma-pick__photo--alt { opacity: 0; }
  .duma-pick:hover:has(.duma-pick__photo--alt) .duma-pick__photo--primary { opacity: 0; }
  .duma-pick:hover .duma-pick__photo--alt { opacity: 1; }

  .duma-pick__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    z-index: 3;
    background: rgba(255, 255, 255, 0.85);
    color: var(--color-foreground, #2b2b2b);
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: 0.08em;
    padding: 5px 11px;
  }

  .duma-pick__badge--sold {
    background: rgba(54, 54, 54, 0.82);
    color: #fff;
  }

  .duma-pick__info {
    text-align: center;
    padding: 18px 8px 6px;
  }

  .duma-pick__name {
    display: block;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-foreground, #2b2b2b);
    margin-bottom: 7px;
    text-decoration: none;
  }

  .duma-pick__price {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--color-foreground, #2b2b2b);
    display: inline-flex;
    gap: 9px;
    align-items: baseline;
    justify-content: center;
  }

  .duma-pick__was {
    text-decoration: line-through;
    color: #6b6663;
    font-size: 0.8125rem;
    font-weight: 400;
  }

  .duma-pick__now { color: #c97070; }

  .duma-pick__form { display: block; }

  .duma-pick__add {
    margin-top: 13px;
    display: inline-block;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-foreground, #2b2b2b);
    background: none;
    border: none;
    border-bottom: 1px solid currentColor;
    padding: 0 0 3px;
    cursor: pointer;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .duma-pick:hover .duma-pick__add {
    opacity: 1;
    transform: translateY(0);
  }

  .duma-pick__add[disabled] {
    color: #6b6663;
    border-color: #ddd7cf;
    cursor: default;
  }

  .duma-picks__arrow {
    position: absolute;
    top: 38%;
    z-index: 5;
    width: 54px;
    height: 54px;
    border: none;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 6px 22px rgba(0, 0, 0, 0.14);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }

  .duma-picks__arrow:hover { transform: scale(1.08); }
  .duma-picks__arrow svg { width: 20px; height: 20px; stroke: var(--color-foreground, #2b2b2b); fill: none; stroke-width: 1.5; }
  .duma-picks__arrow--prev { left: 18px; }
  .duma-picks__arrow--next { right: 18px; }

  .duma-picks__arrow.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .duma-picks__foot {
    text-align: center;
    padding: 46px 0 8px;
  }

  .duma-picks__foot a {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.8125rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-foreground, #2b2b2b);
    display: inline-flex;
    align-items: center;
    gap: 11px;
    text-decoration: none;
    white-space: nowrap;
  }

  .duma-picks__foot-arrow { transition: transform 0.3s ease; }
  .duma-picks__foot a:hover .duma-picks__foot-arrow { transform: translateX(6px); }

  @media screen and (max-width: 749px) {
    .duma-picks__arrow { display: none; }
    .duma-pick { flex-basis: 60vw; }
  }
{% endstylesheet %}

<script>
  (function () {
    var root = document.getElementById('DumaPicks-{{ section.id }}');
    if (!root) return;

    var track = root.querySelector('[data-duma-track]');
    var prev = root.querySelector('[data-duma-prev]');
    var next = root.querySelector('[data-duma-next]');
    if (!track) return;

    function step() {
      var card = track.querySelector('.duma-pick');
      return card ? card.offsetWidth + 8 : 320;
    }

    if (next) next.addEventListener('click', function () { track.scrollBy({ left: step() * 2, behavior: 'smooth' }); });
    if (prev) prev.addEventListener('click', function () { track.scrollBy({ left: -step() * 2, behavior: 'smooth' }); });

    function updateArrows() {
      // No overflow: drop carousel affordances and center the cards.
      var isStatic = track.scrollWidth <= track.clientWidth + 1;
      root.classList.toggle('duma-picks--static', isStatic);
      if (isStatic) return;
      if (prev) prev.classList.toggle('is-hidden', track.scrollLeft < 8);
      if (next) next.classList.toggle('is-hidden', track.scrollLeft > track.scrollWidth - track.clientWidth - 8);
    }
    track.addEventListener('scroll', updateArrows, { passive: true });
    window.addEventListener('resize', updateArrows);

    // drag to scroll
    var down = false, startX = 0, startScroll = 0, moved = 0;
    track.addEventListener('mousedown', function (e) {
      down = true; moved = 0; startX = e.pageX; startScroll = track.scrollLeft;
      track.classList.add('is-dragging');
    });
    window.addEventListener('mouseup', function () { down = false; track.classList.remove('is-dragging'); });
    window.addEventListener('mousemove', function (e) {
      if (!down) return;
      var dx = e.pageX - startX;
      moved += Math.abs(dx);
      track.scrollLeft = startScroll - dx;
    });

    function bindCardLinks() {
      track.querySelectorAll('[data-duma-card-link]').forEach(function (link) {
        link.addEventListener('click', function (e) { if (moved > 6) e.preventDefault(); });
      });
    }
    bindCardLinks();
    updateArrows();

    // Hydration: fetch a URL that re-renders this section server-side
    // (recommendations or search endpoint) and swap the track contents in.
    // Retries on failure — the theme dev proxy rate-limits (429) when hot
    // reload and several section renders land at once.
    function hydrate(url, onSwapped, attempt) {
      attempt = attempt || 0;
      fetch(url)
        .then(function (res) { return res.ok ? res.text() : Promise.reject(res.status); })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var fresh = doc.querySelector('#DumaPicks-{{ section.id }} [data-duma-track]');
          if (fresh && fresh.children.length) {
            track.innerHTML = fresh.innerHTML;
            if (onSwapped) onSwapped();
            bindCardLinks();
            updateArrows();
            root.hidden = false;
          } else {
            root.hidden = true;
          }
        })
        .catch(function () {
          if (attempt < 3) {
            setTimeout(function () { hydrate(url, onSwapped, attempt + 1); }, 1500 * Math.pow(2, attempt));
          } else {
            root.hidden = true;
          }
        });
    }

    // Related-products mode: Shopify product recommendations.
    var recUrl = root.dataset.recommendationsUrl;
    if (recUrl) hydrate(recUrl);

    // Recently-viewed mode: resolve localStorage history (written by
    // recently-viewed-products.js, key "viewedProducts") via the search
    // endpoint, then restore most-recent-first order.
    var rvUrl = root.dataset.recentlyViewedUrl;
    if (rvUrl) {
      var entries = [];
      try { entries = JSON.parse(localStorage.getItem('viewedProducts') || '[]'); } catch (_) {}
      if (!Array.isArray(entries)) entries = [];
      var currentId = root.dataset.currentProductId || '';
      var ids = entries
        .map(function (e) { return e && typeof e === 'object' ? String(e.id) : String(e); })
        .filter(function (id) { return id && id !== 'null' && id !== currentId; })
        .slice(0, parseInt(root.dataset.maxItems || '6', 10));

      if (!ids.length) {
        root.hidden = true;
      } else {
        var q = ids.map(function (id) { return 'id:' + id; }).join(' OR ');
        var url = rvUrl + '?q=' + encodeURIComponent(q) + '&type=product&section_id=' + encodeURIComponent(root.dataset.sectionId);
        hydrate(url, function () {
          var byId = {};
          track.querySelectorAll('.duma-pick[data-product-id]').forEach(function (el) {
            byId[el.dataset.productId] = el;
          });
          ids.forEach(function (id) {
            if (byId[id]) track.appendChild(byId[id]);
          });
        });
      }
    }
  })();
</script>

{% schema %}
{
  "name": "DUMA Our Picks",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Picks"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Products source",
      "options": [
        {
          "value": "collection",
          "label": "Collection"
        },
        {
          "value": "related",
          "label": "Related products (product pages)"
        },
        {
          "value": "recently_viewed",
          "label": "Recently viewed (this visitor)"
        }
      ],
      "default": "collection",
      "info": "Related products uses Shopify recommendations and falls back to the selected collection. Recently viewed uses the visitor's browsing history and hides when empty."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "text",
      "id": "foot_label",
      "label": "Footer link label",
      "default": "View All Products →"
    },
    {
      "type": "url",
      "id": "foot_link",
      "label": "Footer link URL",
      "info": "Defaults to the selected collection."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "checkbox",
      "id": "custom_spacing",
      "label": "Override theme section gap",
      "info": "Default gap comes from Theme settings > DUMA Layout.",
      "default": false
    },
    {
      "type": "range",
      "id": "space_above",
      "label": "Space above",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    },
    {
      "type": "range",
      "id": "space_below",
      "label": "Space below",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    }
  ],
  "presets": [
    {
      "name": "DUMA Our Picks",
      "category": "t:categories.product",
      "settings": {
        "heading": "Our Picks",
        "max_products": 12
      }
    }
  ]
}
{% endschema %}
