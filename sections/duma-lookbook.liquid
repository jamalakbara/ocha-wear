{%- liquid
  assign image = section.settings.image
  assign caption = section.settings.caption
  assign link = section.settings.link
  assign full_width = section.settings.full_width
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{%- render 'duma-section-spacing', section: section -%}

<section
  class="duma-lookbook{% unless full_width %} duma-lookbook--contained{% endunless %} section section--full-width color-{{ section.settings.color_scheme }}"
  style="--duma-lookbook-height: {{ section.settings.height_desktop }}px;"
>
  {%- if link != blank -%}
    <a class="duma-lookbook__media-wrap" href="{{ link }}">
  {%- else -%}
    <div class="duma-lookbook__media-wrap">
  {%- endif -%}
    {%- if image != blank -%}
      <img
        class="duma-lookbook__image"
        src="{{ image | image_url: width: 2880 }}"
        srcset="
          {{ image | image_url: width: 1440 }} 1440w,
          {{ image | image_url: width: 2160 }} 2160w,
          {{ image | image_url: width: 2880 }} 2880w
        "
        sizes="{% if full_width %}100vw{% else %}(min-width: 750px) min(100vw, 1600px), 100vw{% endif %}"
        alt="{{ image.alt | escape }}"
        loading="lazy"
        width="{{ image.width }}"
        height="{{ image.height }}"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'duma-lookbook__image' }}
    {%- endif -%}
  {%- if link != blank -%}
    </a>
  {%- else -%}
    </div>
  {%- endif -%}

  {%- if caption != blank -%}
    <p class="duma-lookbook__caption">{{ caption }}</p>
  {%- endif -%}
</section>

{% stylesheet %}
  .duma-lookbook {
    margin: 0;
    padding: 0 0 var(--padding-3xl);
    width: 100%;
  }

  .duma-lookbook__media-wrap {
    display: block;
    width: 100%;
    height: 60svh;
    overflow: hidden;
  }

  @media screen and (min-width: 750px) {
    .duma-lookbook__media-wrap {
      height: var(--duma-lookbook-height);
    }
  }

  .duma-lookbook--contained .duma-lookbook__media-wrap {
    width: min(100% - 3rem, var(--page-width, 1600px));
    margin-inline: auto;
  }

  .duma-lookbook__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .duma-lookbook__caption {
    margin: var(--padding-xl) auto 0;
    text-align: center;
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-size: clamp(1.25rem, 2vw, 1.45rem);
    font-style: normal;
    letter-spacing: 0.02em;
    color: var(--color-foreground);
    line-height: 1.2;
    max-width: 32rem;
    padding: 0 1.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DUMA Lookbook",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Recommended: 2880 × 1300px (wide panoramic)."
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width image",
      "info": "Uncheck to contain the image within the page width with side margins.",
      "default": true
    },
    {
      "type": "text",
      "id": "caption",
      "label": "Caption",
      "default": "ocha Escape 25",
      "info": "Display serif caption shown centered below the image."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link (optional)"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 650
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "checkbox",
      "id": "custom_spacing",
      "label": "Override theme section gap",
      "info": "Default gap comes from Theme settings > DUMA Layout.",
      "default": false
    },
    {
      "type": "range",
      "id": "space_above",
      "label": "Space above",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    },
    {
      "type": "range",
      "id": "space_below",
      "label": "Space below",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    }
  ],
  "presets": [
    {
      "name": "DUMA Lookbook",
      "category": "t:categories.storytelling"
    }
  ]
}
{% endschema %}
