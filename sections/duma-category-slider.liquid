{%- liquid
  assign tile_count = section.blocks.size
  assign mobile_cols = section.settings.mobile_columns
  assign desktop_cols = section.settings.desktop_columns | default: '4'

  case desktop_cols
    when '2'
      assign tile_vw = '50vw'
    when '3'
      assign tile_vw = '34vw'
    else
      assign tile_vw = '25vw'
  endcase

  if mobile_cols == '2'
    assign mobile_vw = '50vw'
  else
    assign mobile_vw = '100vw'
  endif

  comment
    Tiles use a fixed aspect ratio on every screen size; the CDN crops
    images to the same ratio so what you upload is exactly what renders.
  endcomment
  assign ratio_parts = section.settings.tile_ratio | default: '3/4' | split: '/'
  assign ratio_w = ratio_parts[0] | plus: 0
  assign ratio_h = ratio_parts[1] | plus: 0
-%}

<div class="section-background color-{{ section.settings.color_scheme }}"></div>
{%- render 'duma-section-spacing', section: section -%}

<section
  class="duma-category section section--full-width color-{{ section.settings.color_scheme }}"
  style="--duma-category-ratio: {{ ratio_w }} / {{ ratio_h }}; --duma-category-mobile-cols: {{ mobile_cols }}; --duma-category-cols: {{ desktop_cols }};"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="duma-category__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="duma-category__grid" data-tile-count="{{ tile_count }}">
    {%- for block in section.blocks -%}
      {%- liquid
        assign tile_url = block.settings.link
      -%}
      {%- if tile_url != blank -%}
        <a class="duma-category__tile" href="{{ tile_url }}" {{ block.shopify_attributes }}>
      {%- else -%}
        <div class="duma-category__tile" {{ block.shopify_attributes }}>
      {%- endif -%}
        {%- if block.settings.image != blank -%}
          {%- liquid
            assign img = block.settings.image
            assign h_480 = 480 | times: ratio_h | divided_by: ratio_w
            assign h_800 = 800 | times: ratio_h | divided_by: ratio_w
            assign h_1200 = 1200 | times: ratio_h | divided_by: ratio_w
            assign h_1600 = 1600 | times: ratio_h | divided_by: ratio_w
          -%}
          <img
            class="duma-category__image"
            src="{{ img | image_url: width: 1200, height: h_1200, crop: 'center' }}"
            srcset="
              {{ img | image_url: width: 480, height: h_480, crop: 'center' }} 480w,
              {{ img | image_url: width: 800, height: h_800, crop: 'center' }} 800w,
              {{ img | image_url: width: 1200, height: h_1200, crop: 'center' }} 1200w,
              {{ img | image_url: width: 1600, height: h_1600, crop: 'center' }} 1600w
            "
            sizes="(min-width: 750px) {{ tile_vw }}, {{ mobile_vw }}"
            alt="{{ img.alt | escape }}"
            loading="lazy"
            width="1200"
            height="{{ h_1200 }}"
          >
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'duma-category__image' }}
        {%- endif -%}
        <div class="duma-category__label-wrap">
          {%- if block.settings.label != blank -%}
            <span class="duma-category__label">{{ block.settings.label }}</span>
          {%- endif -%}
          {%- if block.settings.cta_label != blank -%}
            <span class="duma-category__cta">{{ block.settings.cta_label }}</span>
          {%- endif -%}
        </div>
      {%- if tile_url != blank -%}
        </a>
      {%- else -%}
        </div>
      {%- endif -%}
    {%- else -%}
      {%- for i in (1..4) -%}
        <div class="duma-category__tile">
          {{ 'collection-1' | placeholder_svg_tag: 'duma-category__image' }}
          <div class="duma-category__label-wrap">
            <span class="duma-category__label">CATEGORY {{ i }}</span>
            <span class="duma-category__cta">SHOP NOW &rarr;</span>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% stylesheet %}
  .duma-category {
    margin: 0;
    padding: 0;
    width: 100%;
  }

  .duma-category__heading {
    margin: 0;
    padding: 2rem 1rem 1rem;
    text-align: center;
    text-transform: none;
    font-family: var(--font-duma-section, var(--font-subheading--family));
    font-style: italic;
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: -0.02em;
    color: var(--color-foreground-heading);
  }

  .duma-category__grid {
    display: grid;
    grid-template-columns: repeat(var(--duma-category-mobile-cols, 1), 1fr);
    gap: 0;
    width: 100%;
  }

  @media screen and (min-width: 750px) {
    .duma-category__grid {
      grid-template-columns: repeat(var(--duma-category-cols, 4), 1fr);
    }
  }

  .duma-category__tile {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: var(--duma-category-ratio, 3 / 4);
    overflow: hidden;
    color: #fff;
    text-decoration: none;
    background: rgba(0, 0, 0, 0.05);
  }

  .duma-category__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s var(--ease-out-quad, ease-out);
  }

  .duma-category__tile:hover .duma-category__image {
    transform: scale(1.03);
  }

  .duma-category__label-wrap {
    position: absolute;
    inset: auto 0 0 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    padding: 1.25rem 1.5rem;
    pointer-events: none;
    z-index: 2;
  }

  .duma-category__label {
    color: #fff;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 1.0625rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    line-height: 1;
  }

  .duma-category__cta {
    color: #fff;
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 0.625rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    line-height: 1;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DUMA Category Grid",
  "tag": "section",
  "blocks": [
    {
      "type": "category_tile",
      "name": "Category tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Any size ≥1600px wide. Cropped from the center to the section's tile aspect ratio."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "CATEGORY"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Sublink label",
          "default": "SHOP NOW →"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "info": "Optional. Leave blank for image-only grid."
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "4"
    },
    {
      "type": "select",
      "id": "tile_ratio",
      "label": "Tile aspect ratio",
      "info": "Same shape on every screen size. Images are cropped from the center to match.",
      "options": [
        { "value": "2/3", "label": "Portrait 2:3" },
        { "value": "3/4", "label": "Portrait 3:4" },
        { "value": "4/5", "label": "Portrait 4:5" },
        { "value": "1/1", "label": "Square" }
      ],
      "default": "3/4"
    },
    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile columns",
      "options": [
        { "value": "1", "label": "1 (stacked)" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "checkbox",
      "id": "custom_spacing",
      "label": "Override theme section gap",
      "info": "Default gap comes from Theme settings > DUMA Layout.",
      "default": false
    },
    {
      "type": "range",
      "id": "space_above",
      "label": "Space above",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    },
    {
      "type": "range",
      "id": "space_below",
      "label": "Space below",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.custom_spacing }}"
    }
  ],
  "presets": [
    {
      "name": "DUMA Category Grid",
      "category": "t:categories.collection_list",
      "settings": {},
      "blocks": {
        "tile_1": {
          "type": "category_tile",
          "settings": {
            "label": "OUTERWEARS",
            "cta_label": "SHOP NOW →"
          }
        },
        "tile_2": {
          "type": "category_tile",
          "settings": {
            "label": "DRESSES",
            "cta_label": "SHOP NOW →"
          }
        },
        "tile_3": {
          "type": "category_tile",
          "settings": {
            "label": "BOTTOMS",
            "cta_label": "SHOP NOW →"
          }
        },
        "tile_4": {
          "type": "category_tile",
          "settings": {
            "label": "TOPS",
            "cta_label": "SHOP NOW →"
          }
        }
      },
      "block_order": ["tile_1", "tile_2", "tile_3", "tile_4"]
    }
  ]
}
{% endschema %}
