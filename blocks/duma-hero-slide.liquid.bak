{% comment %}
  Schema-only block. Rendering happens inside sections/duma-hero.liquid.
{% endcomment %}

{% schema %}
{
  "name": "Hero slide",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image (1:1)",
      "info": "Square crop shown on mobile. Falls back to the desktop image if empty."
    },
    {
      "type": "text",
      "id": "wordmark",
      "label": "Wordmark",
      "info": "Display serif text centered over the image (e.g. campaign name)."
    },
    {
      "type": "text",
      "id": "subline",
      "label": "Subline",
      "info": "Small caps line under the wordmark."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
