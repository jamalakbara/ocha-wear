{% comment %}
  Schema-only block. Rendering happens inside sections/duma-category-slider.liquid.
{% endcomment %}

{% schema %}
{
  "name": "Category tile",
  "tag": null,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Vertical/portrait photo recommended."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "CATEGORY"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Sublink label",
      "default": "SHOP NOW →"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    }
  ]
}
{% endschema %}
