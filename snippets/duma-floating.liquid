{% comment %}
  ocha wear floating widgets — wishlist tab (right edge) + WhatsApp button (bottom-right).
  Configured under Theme settings → Floating widgets.
{% endcomment %}

{%- if settings.duma_enable_wishlist -%}
  <a
    class="duma-wishlist-tab"
    href="{{ settings.duma_wishlist_url | default: '#' }}"
    aria-label="{{ settings.duma_wishlist_label | default: 'My Wishlist' | escape }}"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-7-4.5-9.5-9C1 9 2.5 5 6 5c2 0 3.2 1.3 4 2.5C10.8 6.3 12 5 14 5c3.5 0 5 4 3.5 7-2.5 4.5-9.5 9-9.5 9Z"/></svg>
    <span>{{ settings.duma_wishlist_label | default: 'My Wishlist' }}</span>
  </a>
{%- endif -%}

{%- if settings.duma_enable_whatsapp and settings.duma_whatsapp_number != blank -%}
  {%- assign wa_text = settings.duma_whatsapp_message | default: '' | url_encode -%}
  <a
    class="duma-whatsapp"
    href="https://wa.me/{{ settings.duma_whatsapp_number }}{% if wa_text != blank %}?text={{ wa_text }}{% endif %}"
    target="_blank"
    rel="noopener"
    aria-label="WhatsApp"
  >
    <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M16 3C9.4 3 4 8.4 4 15c0 2.3.6 4.4 1.7 6.3L4 29l7.9-1.6c1.8 1 3.9 1.5 6.1 1.5 6.6 0 12-5.4 12-12S22.6 3 16 3Zm0 21.8c-1.9 0-3.7-.5-5.3-1.5l-.4-.2-4.1.9.9-4-.2-.4c-1-1.6-1.6-3.5-1.6-5.6 0-5.5 4.5-10 10-10s9.8 4.5 9.8 10-4.4 9.8-9.1 10.8Zm5.5-7.5c-.3-.2-1.8-.9-2-1-.3-.1-.5-.2-.7.1-.2.3-.8 1-.9 1.2-.2.2-.3.2-.6.1-.3-.2-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6l.5-.5c.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5l-.9-2.2c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.2.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.8-.7 2-1.5.3-.7.3-1.4.2-1.5-.1-.1-.3-.2-.5-.3Z"/></svg>
  </a>
{%- endif -%}

{% stylesheet %}
  .duma-wishlist-tab {
    position: fixed;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    background: #fff;
    box-shadow: -2px 0 12px rgba(0, 0, 0, 0.08);
    padding: 18px 9px;
    writing-mode: vertical-rl;
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #2b2b2b;
  }

  .duma-wishlist-tab svg {
    width: 17px;
    height: 17px;
    fill: #2b2b2b;
  }

  .duma-wishlist-tab span {
    font-family: var(--font-duma-ui, var(--font-body--family));
    font-size: 13px;
    letter-spacing: 0.04em;
    color: #2b2b2b;
    transform: rotate(180deg);
  }

  .duma-whatsapp {
    position: fixed;
    right: 26px;
    bottom: 26px;
    z-index: 45;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: #25d366;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.25s ease;
  }

  .duma-whatsapp:hover {
    transform: scale(1.07);
  }

  .duma-whatsapp svg {
    width: 34px;
    height: 34px;
    fill: #fff;
  }

  @media screen and (max-width: 749px) {
    .duma-wishlist-tab {
      padding: 14px 7px;
    }

    .duma-whatsapp {
      width: 54px;
      height: 54px;
      right: 18px;
      bottom: 18px;
    }
  }
{% endstylesheet %}
