{% comment %}
  ocha wear type system.
  Loads the design's Google Fonts (Bodoni Moda display serif, Cormorant Garamond
  headings, Work Sans UI) and remaps the --font-duma-* vars consumed by every
  duma-* section. Falls back to the Shopify-library family if the request fails.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Bodoni+Moda:ital,opsz,wght@0,6..96,400..700;1,6..96,400..600&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Work+Sans:wght@300;400;500;600&display=swap"
>

{% style %}
  :root {
    --font-duma-display: 'Bodoni Moda', var(--font-heading--family);
    --font-duma-section: 'Cormorant Garamond', var(--font-subheading--family);
    --font-duma-ui: 'Work Sans', var(--font-body--family);
  }
{% endstyle %}
